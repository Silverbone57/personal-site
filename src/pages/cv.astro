---
import BaseLayout from "../layouts/BaseLayout.astro";
import TimeLineElement from "../components/cv/TimeLine.astro";
---

<BaseLayout title="Resume | Mobinu Shadhin" sideBarActiveItemID="cv">
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Professional Summary</div>
  </div>

  <div class="mb-10 text-justify leading-relaxed">
    <p>
      High-output sales professional with over 2 years of experience across inbound and outbound environments in insurance and financial services. Proven ability to manage high call volumes, qualify prospects quickly, and move deals through a structured pipeline under real performance metrics. Experienced with CRM platforms, virtual sales tools, and fully remote workflows. Now targeting a tech sales role (SDR/AE) to bring a proven consultative foundation into a high-growth SaaS or B2B environment.
    </p>
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Experience</div>
  </div>

  <div class="time-line-container mb-10">
    <TimeLineElement
      title="Sales Representative"
      subtitle="From June 2026 to Present at Insuredin10, Clearwater, FL"
    >
      <ul class="list-disc list-inside mb-4 ml-2">
        <li>Handle 30+ inbound calls daily from warm leads; conduct 12-15 full discovery and closing conversations per shift.</li>
        <li>Maintain a consistent close rate of ~20%, outperforming team average through targeted objection handling.</li>
        <li>On pace for 11+ sales per week, managing the full cycle from initial call through application submission.</li>
        <li>Track pipeline stages, follow-up cadences, and application status through CRM to ensure zero deals fall through.</li>
      </ul>
    </TimeLineElement>

    <TimeLineElement
      title="Independent Insurance Broker"
      subtitle="From March 2026 to Present at Pinnacle Life Group, Remote"
    >
      <ul class="list-disc list-inside mb-4 ml-2">
        <li>Operate as an independent producer across health and life insurance carriers, managing an active book of business.</li>
        <li>Conduct needs-based consultations to identify optimal private market coverage based on income and health profiles.</li>
        <li>Own full end-to-end client lifecycle: prospecting, quoting, enrollment, and post-sale retention with no handoffs.</li>
      </ul>
    </TimeLineElement>

    <TimeLineElement
      title="Health Insurance Agent"
      subtitle="From September 2025 to March 2026 at US Health Advisors, Tampa, FL"
    >
      <ul class="list-disc list-inside mb-4 ml-2">
        <li>Advised clients on private health insurance plans, identifying coverage gaps and recommending tailored solutions.</li>
        <li>Managed a consistent client pipeline with multi-touch follow-up sequences, maintaining high contact rates.</li>
        <li>Operated as a 1099 independent producer, self-managing daily prospecting and closing activity.</li>
      </ul>
    </TimeLineElement>

    <TimeLineElement
      title="Medicare Sales Agent"
      subtitle="From June 2025 to September 2025 at Exact Medicare, Remote"
    >
      <ul class="list-disc list-inside mb-4 ml-2">
        <li>Educated beneficiaries on Medicare Advantage, Part D, and Medigap plans, conducting 15+ virtual consultations daily.</li>
        <li>Maintained 100% CMS compliance across all enrollment interactions, adhering to strict federal regulatory requirements.</li>
      </ul>
    </TimeLineElement>
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Skills & Tools</div>
  </div>

  <ul class="list-disc md:columns-2 columns-1 mx-6 mb-10">
    <li>Consultative Selling</li>
    <li>Pipeline Management</li>
    <li>Objection Handling</li>
    <li>Inbound & Outbound Sales</li>
    <li>Appointment Setting</li>
    <li>GoHighLevel CRM</li>
    <li>Virtual Dialer Systems</li>
    <li>10DLC SMS Outreach</li>
    <li>Zoom & Microsoft Teams</li>
    <li>Active FL 2-15 License</li>
  </ul>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Education</div>
  </div>

  <div class="time-line-container grid gap-4 mb-10">
    <TimeLineElement
      title="B.A. in Psychology"
      subtitle="August 2025 to May 2027 (Expected) at University of South Florida, Tampa, FL"
    />
    <TimeLineElement
      title="Associate of Arts"
      subtitle="Graduated May 2025 at St. Petersburg College, St. Petersburg, FL"
    />
  </div>
</BaseLayout>
