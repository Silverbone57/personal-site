---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const last_posts = posts.slice(0, 3);
---

<BaseLayout sideBarActiveItemID="home">
  <div class="pb-12 mt-5">
    <div class="text-xl py-1">Hey there 👋</div>
    <div class="text-5xl font-bold">I'm Mobinu Shadhin</div>
    <div class="text-3xl py-3 font-bold">Sales Professional | Pipeline Builder | Remote-Ready</div>
    <div class="py-2">
      <text class="text-lg">
        High-output sales professional with experience across inbound and outbound environments. I specialize in managing high call volumes, qualifying prospects quickly, and moving deals through a structured pipeline under real performance metrics.
      </text>
    </div>
    <div class="mt-8">
      <a class="btn" href="https://www.linkedin.com/in/mobinu-shadhin/" target="_blank"> Let's connect!</a>
    </div>
  </div>

  <div class="mb-14 p-8 bg-base-200 rounded-2xl shadow-sm">
    <div class="text-3xl w-full font-bold mb-4 flex items-center gap-3">
       <svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.486 2 2 6.486 2 12s4.486 10 10 10 10-4.486 10-10S17.514 2 12 2zm0 18c-4.411 0-8-3.589-8-8s3.589-8 8-8 8 3.589 8 8-3.589 8-8 8z"></path><circle cx="12" cy="12" r="6" fill="currentColor" opacity="0.3"></circle><circle cx="12" cy="12" r="3"></circle></svg>
       Track Record & Execution
    </div>
    <div class="text-lg text-left leading-relaxed">
      <p class="mb-4">
        My approach to sales is entirely metrics-driven, focusing on <strong>high-volume execution</strong> and <strong>full-cycle ownership</strong>. 
      </p>
      <p class="mb-4">
        Currently, I handle 30+ inbound calls daily and conduct 12-15 full discovery and closing conversations per shift, maintaining a consistent close rate of ~20%. I operate independent books of business, managing everything from initial prospecting to enrollment and post-sale retention with zero handoffs. 
      </p>
      <p>
        <strong>Tech Stack & Tools:</strong> GoHighLevel CRM, Zoom, Microsoft Teams, Virtual Dialer Systems, 10DLC SMS Outreach.
      </p>
    </div>
  </div>

  <div>
    <div class="text-3xl w-full font-bold mb-2">Key Experience & Pipeline Mastery</div>
  </div>

  <HorizontalCard
    title="Full-Cycle Sales Representative"
    img="/inbound-sales.jpg"
    desc="On pace for 11+ sales per week with an average AP of $75/month, outperforming team averages through active listening and targeted objection handling."
    url="/cv"
    badge="Inbound Execution"
  />
  <div class="divider my-0"></div>

  <HorizontalCard
    title="Independent Insurance Broker"
    img="/pipeline.jpg"
    desc="Operated across health and life insurance carriers, managing active pipelines for self-employed individuals and privately insured clients."
    url="/cv"
    badge="Full-Cycle"
  />
  <div class="divider my-0"></div>

  <HorizontalCard
    title="CRM & Outbound Strategy"
    img="/crm-tech.jpg"
    desc="Built and managed client pipelines with multi-touch follow-up sequences using GoHighLevel and virtual dialers to ensure high contact rates."
    url="/cv"
    badge="Tech Fluency"
  />

</BaseLayout>
